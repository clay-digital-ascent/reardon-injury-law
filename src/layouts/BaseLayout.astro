---
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  currentPage?: string;
  includeAnimationsCSS?: boolean;
  extraHeadStyles?: string;
  ogImage?: string;
  pageType?: string;
}

const {
  title,
  description = "Reardon Injury Law - Personal injury attorneys serving all of California. Free consultation. No fees unless we win.",
  bodyClass = "body",
  currentPage = "",
  includeAnimationsCSS = false,
  extraHeadStyles = "",
  ogImage = "/images/REARDON-LOGO.avif",
  pageType = "website",
} = Astro.props;

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || "https://reardoninjurylaw.com";
const canonicalURL = `${siteUrl}${Astro.url.pathname}`;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": "Reardon Injury Law",
  "url": siteUrl,
  "logo": `${siteUrl}/images/REARDON-LOGO.avif`,
  "telephone": "+1-657-522-7122",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Huntington Beach",
    "addressRegion": "CA",
    "postalCode": "92648",
    "addressCountry": "US"
  },
  "description": "Personal injury attorneys serving all of California. Led by John Reardon, with 20 years of chiropractic experience before becoming an attorney.",
  "priceRange": "Free Consultation",
  "areaServed": {
    "@type": "State",
    "name": "California"
  },
  "knowsAbout": [
    "Personal Injury Law",
    "Car Accidents",
    "Motorcycle Accidents",
    "Truck Accidents",
    "Bicycle Accidents",
    "Pedestrian Accidents",
    "Rideshare Accidents"
  ]
};

const GA4_ID = import.meta.env.PUBLIC_GA4_ID || "";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <link rel="canonical" href={canonicalURL}>
  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={pageType}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImageURL}>
  <meta property="og:site_name" content="Reardon Injury Law">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>
  <!-- JSON-LD Schema -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaOrg)}</script>`} />
  {GA4_ID && (
    <Fragment set:html={`<script async src="https://www.googletagmanager.com/gtag/js?id=${GA4_ID}"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_ID}');</script>`} />
  )}
  <link href="/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/reardon-injury-law.webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/enhancements.css?v=accordion-fix-004" rel="stylesheet" type="text/css">
  {includeAnimationsCSS && <link href="/css/animations.css?v=55a5a7d" rel="stylesheet" type="text/css" />}
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous">
  <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript"></script>
  <script is:inline>WebFont.load({google:{families:["Montserrat:100,100italic,200,200italic,300,300italic,400,400italic,500,500italic,600,600italic,700,700italic,800,800italic,900,900italic","Open Sans:300,300italic,400,400italic,600,600italic,700,700italic,800,800italic"]}});</script>
  <script is:inline>!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof o.DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>
  <link href="/images/favicon.ico" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">
  {extraHeadStyles && <Fragment set:html={extraHeadStyles} />}
  <style is:inline>
    .loc-dropdown { position: relative; display: inline-block; }
    .loc-panel {
      display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
      background: #1a1a1b; border: 1px solid rgba(238,186,107,0.2); border-radius: 12px;
      padding: 16px 24px 12px; z-index: 1000; min-width: 280px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.5);
    }
    .loc-dropdown:hover .loc-panel { display: block; }
    .loc-county-hdr {
      display: flex; justify-content: space-between; align-items: center; cursor: pointer;
      color: #ffffff; font-family: Montserrat, sans-serif; font-size: 15px; font-weight: 600;
      padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.08); transition: color 0.2s;
      user-select: none;
    }
    .loc-county-hdr:hover, .loc-county-hdr.active { color: #eeba6b; }
    .loc-county-hdr .loc-chev {
      font-size: 9px; opacity: 0.5; transition: transform 0.25s;
    }
    .loc-county-hdr.active .loc-chev { transform: rotate(180deg); opacity: 0.8; }
    .loc-cities { display: none; padding: 4px 0 6px 16px; }
    .loc-cities.open { display: block; }
    .loc-city {
      display: block; color: #ffffff; font-family: 'Open Sans', sans-serif;
      font-size: 14.5px; padding: 6px 0; text-decoration: none; transition: color 0.15s;
    }
    .loc-city:hover { color: #eeba6b; }
    .loc-panel-footer {
      margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(238,186,107,0.12); text-align: center;
    }
    .loc-view-all {
      color: #eeba6b; font-family: Montserrat, sans-serif; font-size: 12px; font-weight: 600;
      text-decoration: none; text-transform: uppercase; letter-spacing: 0.5px; transition: opacity 0.2s;
    }
    .loc-view-all:hover { opacity: 0.7; }
    @media (max-width: 991px) {
      .loc-dropdown { display: contents; }
      .loc-panel { display: none !important; }
    }
  </style>
</head>
<body class={bodyClass}>
  <div class="page-wrapper">
    <div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar-2 w-nav">
      <div class="container-10 w-container">
        <a href="/" class:list={["ril-logo w-nav-brand", { "w--current": currentPage === "home" }]}>
          <img src="/images/REARDON-LOGO.avif" loading="lazy" alt="Reardon Injury Law" class="ril-logoo">
        </a>
        <nav role="navigation" class="nav-menu-2 w-nav-menu">
          <a href="/" class:list={["nav-link w-nav-link", { "w--current": currentPage === "home" }]}>HOME</a>
          <a href="/about" class:list={["nav-link w-nav-link", { "w--current": currentPage === "about" }]}>ABOUT</a>
          <a href="/practice-areas" class:list={["nav-link w-nav-link", { "w--current": currentPage === "practice-areas" }]}>PRACTICE AREAS</a>
          <div class="loc-dropdown">
            <a href="/locations" class:list={["nav-link w-nav-link", { "w--current": currentPage === "locations" }]}>LOCATIONS</a>
            <div class="loc-panel">
              <div class="loc-county-hdr" data-county="oc">Orange County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="oc">
                <a href="/locations/huntington-beach" class="loc-city">Huntington Beach</a>
                <a href="/locations/anaheim" class="loc-city">Anaheim</a>
                <a href="/locations/irvine" class="loc-city">Irvine</a>
                <a href="/locations/santa-ana" class="loc-city">Santa Ana</a>
                <a href="/locations/newport-beach" class="loc-city">Newport Beach</a>
              </div>
              <div class="loc-county-hdr" data-county="la">Los Angeles County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="la">
                <a href="/locations/los-angeles" class="loc-city">Los Angeles</a>
                <a href="/locations/long-beach" class="loc-city">Long Beach</a>
                <a href="/locations/pasadena" class="loc-city">Pasadena</a>
                <a href="/locations/santa-monica" class="loc-city">Santa Monica</a>
              </div>
              <div class="loc-county-hdr" data-county="sd">San Diego County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="sd">
                <a href="/locations/san-diego" class="loc-city">San Diego</a>
                <a href="/locations/chula-vista" class="loc-city">Chula Vista</a>
                <a href="/locations/oceanside" class="loc-city">Oceanside</a>
              </div>
              <div class="loc-county-hdr" data-county="sc">Santa Clara County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="sc">
                <a href="/locations/san-jose" class="loc-city">San Jose</a>
                <a href="/locations/santa-clara" class="loc-city">Santa Clara</a>
              </div>
              <div class="loc-county-hdr" data-county="sf">San Francisco <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="sf">
                <a href="/locations/san-francisco" class="loc-city">San Francisco</a>
              </div>
              <div class="loc-county-hdr" data-county="sac">Sacramento County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="sac">
                <a href="/locations/sacramento" class="loc-city">Sacramento</a>
                <a href="/locations/elk-grove" class="loc-city">Elk Grove</a>
              </div>
              <div class="loc-county-hdr" data-county="sb">San Bernardino County <span class="loc-chev">&#9660;</span></div>
              <div class="loc-cities" data-county="sb">
                <a href="/locations/san-bernardino" class="loc-city">San Bernardino</a>
              </div>
              <div class="loc-panel-footer">
                <a href="/locations" class="loc-view-all">View All Locations &rarr;</a>
              </div>
            </div>
          </div>
          <a href="/blog" class:list={["nav-link w-nav-link", { "w--current": currentPage === "blog" }]}>BLOG</a>
          <a href="/contact-page" class:list={["nav-link w-nav-link", { "w--current": currentPage === "contact" }]}>CONTACT US</a>
        </nav>
        <div class="w-nav-button">
          <div class="w-icon-nav-menu"></div>
        </div>
      </div>
    </div>

    <slot />

    <footer class="ril-footer">
      <div class="w-layout-blockcontainer container-19 w-container">
        <div class="div-block-22">
          <img src="/images/REARDON-LOGO.avif" loading="lazy" width="462" alt="Reardon Injury Law" class="ril-logo-footer">
          <div class="div-block-23">
            <div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="w-nav">
              <div class="w-container">
                <nav role="navigation" class="w-nav-menu">
                  <a href="/" class="nav-bottom w-nav-link">HOME</a>
                  <a href="/about" class="nav-bottom w-nav-link">ABOUT</a>
                  <a href="/practice-areas" class="nav-bottom w-nav-link">PRACTICE AREAS</a>
                  <a href="/locations" class="nav-bottom w-nav-link">LOCATIONS</a>
                  <a href="/blog" class="nav-bottom w-nav-link">BLOG</a>
                  <a href="/contact-page" class="nav-bottom w-nav-link">CONTACT US</a>
                </nav>
                <div class="w-nav-button">
                  <div class="w-icon-nav-menu"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="footer-text">&copy; Reardon Injury Law &ndash; All Rights Reserved. For informational purposes only. Not legal advice. Serving personal injury clients across California.</div>
        </div>
      </div>
    </footer>
  </div>

  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=69168ebd4e1b0d16781f5905" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script src="/js/enhancements.js?v=accordion-fix-004" type="text/javascript"></script>
  {includeAnimationsCSS && <script src="/js/animations.js" type="text/javascript"></script>}
  <script is:inline>
    (function(){document.querySelectorAll(".accordion-text-block,.accordion-text-block *").forEach(function(e){e.removeAttribute("data-w-id");});})();
  </script>
  <script is:inline>
    (function(){
      document.querySelectorAll('.loc-county-hdr').forEach(function(hdr){
        hdr.addEventListener('click', function(e){
          e.stopPropagation();
          var county = hdr.getAttribute('data-county');
          var cities = document.querySelector('.loc-cities[data-county="'+county+'"]');
          var isOpen = cities.classList.contains('open');
          // close all
          document.querySelectorAll('.loc-cities').forEach(function(c){ c.classList.remove('open'); });
          document.querySelectorAll('.loc-county-hdr').forEach(function(h){ h.classList.remove('active'); });
          // toggle this one
          if(!isOpen){ cities.classList.add('open'); hdr.classList.add('active'); }
        });
      });
    })();
  </script>
  <script src="/js/webflow.js" type="text/javascript"></script>
  <script src="/js/accordion.js?v=accordion-fix-006" type="text/javascript"></script>
  <script src="/js/reveal.js?v=55a5a7d" defer></script>

  <div class="sticky-mobile-cta">
    <a href="tel:6575227122">&#x1F4DE; Call Now - Free Consultation</a>
  </div>
</body>
</html>
