---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allCities = await getCollection("cities");
const countyMap: Record<string, typeof allCities> = {};
for (const city of allCities) {
  const county = city.data.county;
  if (!countyMap[county]) countyMap[county] = [];
  countyMap[county].push(city);
}
// Office counties first, then all remaining alphabetically
const priorityCounties = ["Orange County", "Los Angeles County", "San Diego County", "Santa Clara County", "San Bernardino County"];
const allCountyNames = Object.keys(countyMap).sort();
const remainingCounties = allCountyNames.filter(c => !priorityCounties.includes(c));
const sortedCounties = [...priorityCounties.filter(c => countyMap[c]), ...remainingCounties];

const extraStyles = `<style>
.card-link:hover .settlement-card {
  background: linear-gradient(180deg, #f0c86f 0%, #d4a84f 100%);
  transition: all 0.25s ease;
  cursor: pointer;
}
.card-link:hover .card-top-bar {
  background-color: #f0c86f;
  transition: background-color 0.25s ease;
}
.card-link:hover .card-title {
  color: #ffffff;
  transition: color 0.25s ease;
}
.card-link:hover .car-image {
  filter: brightness(1.08);
  transition: filter 0.25s ease;
}
</style>`;
---
<BaseLayout title="Locations | Reardon Injury Law" bodyClass="body-7" currentPage="locations" extraHeadStyles={extraStyles}>
  <section class="sectionnn locations-page">
    <div class="w-layout-blockcontainer container-18 w-container">
      <div><h1 class="text-headings sr-left">Office Locations</h1></div>
    </div>
    <div class="w-layout-blockcontainer container-17 w-container sr-stagger">
      <div class="office-locations sr-child"><img src="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif" loading="lazy" width="588" sizes="(max-width: 767px) 100vw, 588px" alt="" srcset="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-500.avif 500w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-800.avif 800w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1080.avif 1080w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1600.avif 1600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2000.avif 2000w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2600.avif 2600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif 4032w" class="image-office-locations"><div><h2 class="heading-for-office-locations sr-up">Orange County</h2><div class="text-block-officelocations">20902 Brookhurst St 101<br>Huntington Beach | California | 92646</div></div></div>
