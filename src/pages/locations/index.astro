---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();
}

const allCities = await getCollection("cities");
const countyMap: Record<string, typeof allCities> = {};
for (const city of allCities) {
  const county = city.data.county;
  if (!countyMap[county]) countyMap[county] = [];
  countyMap[county].push(city);
}
// Office counties first, then all remaining alphabetically
const priorityCounties = ["Orange County", "Los Angeles County", "San Diego County", "Santa Clara County", "San Bernardino County"];
const allCountyNames = Object.keys(countyMap).sort();
const remainingCounties = allCountyNames.filter(c => !priorityCounties.includes(c));
const sortedCounties = [...priorityCounties.filter(c => countyMap[c]), ...remainingCounties];

const extraStyles = `<style>
.card-link:hover .settlement-card {
  background: linear-gradient(180deg, #f0c86f 0%, #d4a84f 100%);
  transition: all 0.25s ease;
  cursor: pointer;
}
.card-link:hover .card-top-bar {
  background-color: #f0c86f;
  transition: background-color 0.25s ease;
}
.card-link:hover .card-title {
  color: #ffffff;
  transition: color 0.25s ease;
}
.card-link:hover .car-image {
  filter: brightness(1.08);
  transition: filter 0.25s ease;
}
</style>`;
---
<BaseLayout title="Locations | Reardon Injury Law" bodyClass="body-7" currentPage="locations" extraHeadStyles={extraStyles}>
  <section class="sectionnn locations-page">
    <div class="w-layout-blockcontainer container-18 w-container">
      <div><h1 class="text-headings sr-left">Office Locations</h1></div>
    </div>
    <div class="w-layout-blockcontainer container-17 w-container sr-stagger">
      <div class="office-locations sr-child"><img src="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif" loading="lazy" width="588" sizes="(max-width: 767px) 100vw, 588px" alt="" srcset="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-500.avif 500w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-800.avif 800w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1080.avif 1080w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1600.avif 1600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2000.avif 2000w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2600.avif 2600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif 4032w" class="image-office-locations"><div><h2 class="heading-for-office-locations sr-up">Orange County</h2><div class="text-block-officelocations">20902 Brookhurst St 101<br>Huntington Beach | California | 92646</div></div></div>
      <div class="office-locations sr-child"><div><h2 class="heading-for-office-locations sr-up">Silicon Valley</h2><div class="text-block-officelocations">325 1st St. Suite 120<br>San Jose | California | 95113</div></div><img src="/images/hardik-pandya--Ey_0PMz900-unsplash.jpg" loading="lazy" width="651" sizes="(max-width: 767px) 100vw, 651px" alt="" srcset="/images/hardik-pandya--Ey_0PMz900-unsplash-p-500.jpg 500w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-800.jpg 800w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-1080.jpg 1080w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-1600.jpg 1600w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-2000.jpg 2000w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-2600.jpg 2600w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-3200.jpg 3200w, /images/hardik-pandya--Ey_0PMz900-unsplash.jpg 4001w" class="image-office-locations"></div>
      <div class="office-locations sr-child"><img src="/images/cedric-letsch-FYDNbPE9Bw4-unsplash.jpg" loading="lazy" width="620" sizes="(max-width: 767px) 100vw, 620px" alt="" srcset="/images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-500.jpg 500w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-800.jpg 800w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-1080.jpg 1080w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-1600.jpg 1600w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-2000.jpg 2000w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-2600.jpg 2600w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash.jpg 3000w" class="image-office-locations"><div><h2 class="heading-for-office-locations sr-up">Inland Empire</h2><div class="text-block-officelocations">1014 N. D St. <br>San Bernardino | California | 92410</div></div></div>
      <div class="office-locations sr-child"><div><h2 class="heading-for-office-locations sr-up">San Diego County</h2><div class="text-block-officelocations">111 C St.<br>Encinitas | California | 92024</div></div><img src="/images/felix-wostmann-RIHKx32ACME-unsplash.jpg" loading="lazy" width="653" sizes="(max-width: 767px) 100vw, 653px" alt="" srcset="/images/felix-wostmann-RIHKx32ACME-unsplash-p-500.jpg 500w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-800.jpg 800w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-1080.jpg 1080w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-1600.jpg 1600w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-2000.jpg 2000w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-2600.jpg 2600w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-3200.jpg 3200w, /images/felix-wostmann-RIHKx32ACME-unsplash.jpg 4898w" class="image-office-locations"></div>
      <div class="office-locations sr-child"><img src="/images/cedric-letsch-UZVlSjrIJ3o-unsplash.jpg" loading="lazy" width="681" sizes="(max-width: 767px) 100vw, 681px" alt="" srcset="/images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-500.jpg 500w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-800.jpg 800w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-1080.jpg 1080w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-1600.jpg 1600w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-2000.jpg 2000w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-2600.jpg 2600w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash.jpg 3000w" class="image-office-locations"><div><h2 class="heading-for-office-locations sr-up">Los Angeles County</h2><div class="text-block-officelocations">440 East Route 66<br>Glendora | California | 91740</div></div></div>
    </div>
  </section>

  <!-- Areas We Serve -->
  <section id="areas-we-serve" style="padding: 80px 20px 60px; background: linear-gradient(180deg, #1a1a1b 0%, #141415 100%); border-top: 1px solid rgba(238,186,107,0.15);">
    <div class="w-layout-blockcontainer w-container" style="max-width: 1100px;">
      <h2 style="color: #eeba6b; font-family: Montserrat, sans-serif; font-size: 36px; font-weight: 700; text-align: center; margin-bottom: 12px;">Areas We Serve</h2>
      <p style="color: rgba(255,255,255,0.7); font-family: 'Open Sans', sans-serif; font-size: 17px; text-align: center; margin-bottom: 16px; max-width: 650px; margin-left: auto; margin-right: auto;">Reardon Injury Law represents personal injury clients across all 58 California counties. Click a county to see the cities we serve.</p>
      <p style="color: rgba(238,186,107,0.6); font-family: 'Open Sans', sans-serif; font-size: 14px; text-align: center; margin-bottom: 30px;">58 counties &middot; {allCities.length} cities</p>

      <div class="county-search-wrap">
        <input type="text" id="county-search" class="county-search" placeholder="Search cities or counties..." autocomplete="off" />
      </div>

      <div class="county-accordion-grid">
        {sortedCounties.map((county, i) => (
          <div class={`county-accordion${priorityCounties.includes(county) ? ' county-priority' : ''}`} data-county={county}>
            <button class="county-accordion-btn" type="button" aria-expanded="false">
              <a href={`/locations/${slugify(county)}/`} class="county-name-link" onclick="event.stopPropagation();">{county.replace(' County', '')}</a>
              <span class="county-count">{countyMap[county].length} {countyMap[county].length === 1 ? 'city' : 'cities'}</span>
              <svg class="county-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="county-cities-panel">
              <div class="county-cities-grid">
                {countyMap[county].sort((a, b) => a.data.city.localeCompare(b.data.city)).map(city => (
                  <a href={`/locations/${slugify(city.data.county)}/${city.slug}/`} class="area-city-card">
                    <span class="city-name">{city.data.city}</span>
                  </a>
                ))}
                <a href={`/locations/${slugify(county)}/`} class="area-city-card county-view-all">
                  <span class="city-name">View all {county.replace(' County', '')} &rarr;</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="form locations-pagee sr-up">
    <div class="w-layout-blockcontainer container-22 w-container">
      <div class="cta-header"><h1 class="cta-headerr sr-up">Contact us now!</h1></div>
      <div><div class="textblockk">Our team will follow up with you as soon as possible.</div></div>
      <div>
        <div class="w-form">
          <form id="email-form" name="email-form" data-name="Email Form" method="get" class="form-2"><label for="name" class="field-label-2">Name</label><input class="text-field w-input" maxlength="256" name="name" data-name="Name" placeholder="" type="text" id="name"><label for="email" class="field-label">Email Address</label><input class="text-field-2 w-input" maxlength="256" name="email" data-name="Email" placeholder="" type="email" id="email" required=""><label for="message" class="field-label">Message to Our Team</label><textarea class="text-field-2 w-input" maxlength="1000" name="message" data-name="Message" placeholder="" id="message" required=""></textarea><input type="submit" data-wait="Please wait..." class="submit-button w-button" value="Submit"></form>
          <div class="w-form-done"><div>Thank you! Your submission has been received!</div></div>
          <div class="w-form-fail"><div>Oops! Something went wrong while submitting the form.</div></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Search */
  .county-search-wrap {
    max-width: 400px;
    margin: 0 auto 30px;
  }
  .county-search {
    width: 100%;
    padding: 12px 18px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    color: #ffffff;
    font-family: 'Open Sans', sans-serif;
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .county-search::placeholder { color: rgba(255,255,255,0.35); }
  .county-search:focus { border-color: rgba(238,186,107,0.5); }

  /* Masonry columns layout — items flow independently per column */
  .county-accordion-grid {
    columns: 3;
    column-gap: 10px;
  }
  @media (max-width: 991px) {
    .county-accordion-grid { columns: 2; }
  }
  @media (max-width: 600px) {
    .county-accordion-grid { columns: 1; }
  }

  .county-accordion {
    break-inside: avoid;
    margin-bottom: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .county-accordion:hover {
    border-color: rgba(238,186,107,0.25);
  }
  .county-accordion.county-hidden {
    display: none;
  }
  .county-priority {
    border-color: rgba(238,186,107,0.2);
  }

  .county-accordion-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    background: rgba(255,255,255,0.03);
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }
  .county-accordion-btn:hover {
    background: rgba(238,186,107,0.06);
  }
  .county-name-link {
    color: #ffffff;
    font-family: Montserrat, sans-serif;
    font-size: 14px;
    font-weight: 600;
    flex: 1;
    text-decoration: none;
    transition: color 0.2s;
  }
  .county-name-link:hover {
    color: #eeba6b;
    text-decoration: underline;
  }
  .county-priority .county-name-link {
    color: #eeba6b;
  }
  .county-count {
    color: rgba(255,255,255,0.35);
    font-family: 'Open Sans', sans-serif;
    font-size: 12px;
    flex-shrink: 0;
  }
  .county-chevron {
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }
  .county-accordion.open .county-chevron {
    transform: rotate(180deg);
  }

  .county-cities-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .county-accordion.open .county-cities-panel {
    max-height: 280px;
    overflow-y: auto;
  }
  /* Scrollbar styling */
  .county-cities-panel::-webkit-scrollbar { width: 6px; }
  .county-cities-panel::-webkit-scrollbar-track { background: transparent; }
  .county-cities-panel::-webkit-scrollbar-thumb {
    background: rgba(238,186,107,0.3);
    border-radius: 3px;
  }

  .county-cities-grid {
    padding: 4px 12px 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .area-city-card {
    display: inline-block;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    padding: 6px 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .area-city-card:hover {
    border-color: rgba(238,186,107,0.4);
    background: rgba(238,186,107,0.08);
  }
  .area-city-card.city-hidden { display: none; }
  .county-view-all {
    border-color: rgba(238,186,107,0.2);
    background: rgba(238,186,107,0.06);
  }
  .county-view-all .city-name {
    color: #eeba6b;
    font-size: 12px;
  }
  .city-name {
    color: #ffffff;
    font-family: 'Open Sans', sans-serif;
    font-size: 13px;
  }
  .area-city-card:hover .city-name {
    color: #eeba6b;
  }
</style>

<script is:inline>
(function() {
  // Accordion toggle
  document.querySelectorAll('.county-accordion-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var acc = btn.closest('.county-accordion');
      var wasOpen = acc.classList.contains('open');
      acc.classList.toggle('open');
      btn.setAttribute('aria-expanded', wasOpen ? 'false' : 'true');
    });
  });

  // Search — filters counties and cities
  var searchInput = document.getElementById('county-search');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      document.querySelectorAll('.county-accordion').forEach(function(acc) {
        var countyName = acc.getAttribute('data-county').toLowerCase();
        var cities = acc.querySelectorAll('.area-city-card');
        var countyMatch = countyName.indexOf(q) !== -1;
        var anyCity = false;

        cities.forEach(function(card) {
          var cityName = card.querySelector('.city-name').textContent.toLowerCase();
          if (q === '' || countyMatch || cityName.indexOf(q) !== -1) {
            card.classList.remove('city-hidden');
            anyCity = true;
          } else {
            card.classList.add('city-hidden');
          }
        });

        if (q === '') {
          acc.classList.remove('county-hidden');
          acc.classList.remove('open');
          acc.querySelector('.county-accordion-btn').setAttribute('aria-expanded', 'false');
        } else if (countyMatch || anyCity) {
          acc.classList.remove('county-hidden');
          acc.classList.add('open');
          acc.querySelector('.county-accordion-btn').setAttribute('aria-expanded', 'true');
        } else {
          acc.classList.add('county-hidden');
          acc.classList.remove('open');
        }
      });
    });
  }

  // Smooth scroll to #areas-we-serve on page load
  if (window.location.hash === '#areas-we-serve') {
    setTimeout(function() {
      var el = document.getElementById('areas-we-serve');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }, 300);
  }
})();
</script>
