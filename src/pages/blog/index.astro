---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function estimateReadTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---
<BaseLayout title="Blog | Reardon Injury Law" description="Legal insights, injury prevention tips, and personal injury law updates from Reardon Injury Law." currentPage="blog">
  <section class="sectionnn" style="padding: 60px 20px 30px;">
    <div class="w-layout-blockcontainer w-container" style="max-width: 900px;">
      <h1 class="text-headings sr-up" style="text-align: center; margin-bottom: 16px;">Blog</h1>
      <p style="color: rgba(255,255,255,0.8); font-family: 'Open Sans', sans-serif; font-size: 18px; text-align: center; line-height: 1.6; max-width: 600px; margin: 0 auto;">Legal insights, injury prevention tips, and updates from our team.</p>
    </div>
  </section>

  <section class="sectionnn" style="padding: 20px 20px 80px;">
    <div class="w-layout-blockcontainer w-container" style="max-width: 900px;">
      {posts.length === 0 && (
        <p style="color: rgba(255,255,255,0.6); text-align: center; font-family: 'Open Sans', sans-serif;">No posts yet. Check back soon!</p>
      )}

      <div class="sr-stagger" style="display: flex; flex-direction: column; gap: 24px;">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="sr-child" style="text-decoration: none; display: block; background: linear-gradient(180deg, #1e1e1f 0%, #141415 100%); border: 1px solid rgba(238,186,107,0.15); border-radius: 12px; padding: 32px; transition: border-color 0.3s ease, transform 0.3s ease;" onmouseover="this.style.borderColor='rgba(238,186,107,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(238,186,107,0.15)';this.style.transform='translateY(0)'">
            <div style="display: flex; gap: 12px; align-items: center; margin-bottom: 12px;">
              <span style="background: rgba(238,186,107,0.15); color: #eeba6b; font-family: Montserrat, sans-serif; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px;">{post.data.category}</span>
              <span style="color: rgba(255,255,255,0.5); font-family: 'Open Sans', sans-serif; font-size: 13px;">{formatDate(post.data.date)}</span>
              <span style="color: rgba(255,255,255,0.4); font-family: 'Open Sans', sans-serif; font-size: 13px;">&middot; {estimateReadTime(post.body ?? "")} min read</span>
            </div>
            <h2 style="color: #ffffff; font-family: Montserrat, sans-serif; font-size: 22px; font-weight: 600; margin-bottom: 10px; line-height: 1.3;">{post.data.title}</h2>
            <p style="color: rgba(255,255,255,0.7); font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6; margin: 0;">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
