---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What types of cases does Reardon Injury Law handle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Reardon Injury Law focuses exclusively on personal injury cases, including car accidents, motorcycle accidents, truck accidents, rideshare accidents (Uber/Lyft), pedestrian accidents, and bicycle accidents. We also handle injuries related to unsafe premises and dog bites."
      }
    },
    {
      "@type": "Question",
      "name": "Does Reardon Injury Law serve all of California?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — we represent clients throughout the entire state of California. Whether your accident happened in Los Angeles, Orange County, San Diego, the Inland Empire, or anywhere else in the state, we can take your case."
      }
    },
    {
      "@type": "Question",
      "name": "Why should I choose Reardon Injury Law?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The firm is led by John Reardon, a retired chiropractor with 20 years of clinical experience. Because of his medical background, he understands injuries at a deeper level than most attorneys — and he knows how to protect clients from being taken advantage of by insurance companies or unethical medical providers."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to hire Reardon Injury Law?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are no upfront costs, ever. We work on a contingency fee, meaning you pay nothing unless we win your case. Our fee is simply a percentage of the settlement."
      }
    },
    {
      "@type": "Question",
      "name": "How is Reardon Injury Law different from other law firms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Medical expertise: John Reardon spent two decades treating accident victims as a chiropractor. Chiropractor relationships: He built one of the largest networks of ethical chiropractors in California. Personal attention: You work directly with an attorney, not a giant call-center firm. Aggressive representation with transparent communication from start to finish."
      }
    }
  ]
});

const extraHead = `<script type="application/ld+json">${faqSchema}</script>`;
---
<BaseLayout title="Reardon Injury Law | Personal Injury Attorneys in California" currentPage="home" includeAnimationsCSS={true} extraHeadStyles={extraHead}>
  <div class="ril-page-main">
    <section class="hero-section">
      <div class="cover-image">
        <div class="div-block-24 sr-up">
          <h1 class="heading-16 front-page">Hurt? We Make it Personal.</h1>
          <div class="text-block-9">Speak with one of our attorneys today.</div>
          <a href="tel:6575227122" class="button-3 w-button">Call Now</a>
        </div>
      </div>
    </section>
  </div>
  <section class="sectionnn image">
    <div class="div-block-31">
      <div class="w-layout-blockcontainer container-23 w-container">
        <h2 class="text-headings locations-thour reveal sr-up">Locations Throughout All of California</h2>
      </div>
    </div>
    <div class="w-layout-blockcontainer container-24 w-container">
      <div class="page-wrapperr">
        <div class="locations-wrapper reveal-left">
          <img src="/images/20251201_2219_California-Office-Map_remix_01kbeh46hheawtytpqfg70dr4s.png" loading="lazy" width="922" sizes="(max-width: 767px) 95vw, (max-width: 991px) 45vw, 50vw" alt="California Map showing office locations" srcset="/images/20251201_2219_California-Office-Map_remix_01kbeh46hheawtytpqfg70dr4s-p-500.png 500w, /images/20251201_2219_California-Office-Map_remix_01kbeh46hheawtytpqfg70dr4s-p-800.png 800w, /images/20251201_2219_California-Office-Map_remix_01kbeh46hheawtytpqfg70dr4s.png 1024w" class="image-9">
        </div>
        <div class="faq-list-wrapper reveal-right">
          <div class="accordion-text-block">
            <div class="div-block-29">
              <h2 class="heading-22">What types of cases does Reardon Injury Law handle?</h2>
              <svg class="questions-button" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="div-block-30">
              <div class="text-block-17">Reardon Injury Law focuses exclusively on personal injury cases, including car accidents, motorcycle accidents, truck accidents, rideshare accidents (Uber/Lyft), pedestrian accidents, and bicycle accidents. We also handle injuries related to unsafe premises and dog bites.</div>
            </div>
          </div>
          <div class="accordion-text-block">
            <div class="div-block-29">
              <h2 class="heading-22">Does Reardon Injury Law serve all of California?</h2>
              <svg class="questions-button" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="div-block-30">
              <div class="text-block-17">Yes &#8212; we represent clients throughout the entire state of California. Whether your accident happened in Los Angeles, Orange County, San Diego, the Inland Empire, or anywhere else in the state, we can take your case.</div>
            </div>
          </div>
          <div class="accordion-text-block">
            <div class="div-block-29">
              <h2 class="heading-22">Why should I choose Reardon Injury Law?</h2>
              <svg class="questions-button" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="div-block-30">
              <div class="text-block-17">The firm is led by John Reardon, a retired chiropractor with 20 years of clinical experience. Because of his medical background, he understands injuries at a deeper level than most attorneys &#8212; and he knows how to protect clients from being taken advantage of by insurance companies or unethical medical providers.</div>
            </div>
          </div>
          <div class="accordion-text-block">
            <div class="div-block-29">
              <h2 class="heading-22">How much does it cost to hire Reardon Injury Law?</h2>
              <svg class="questions-button" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="div-block-30">
              <div class="text-block-17">There are no upfront costs, ever.<br>We work on a contingency fee, meaning you pay nothing unless we win your case. Our fee is simply a percentage of the settlement.</div>
            </div>
          </div>
          <div class="accordion-text-block">
            <div class="div-block-29">
              <h2 class="heading-22">How is Reardon Injury Law different from other law firms?</h2>
              <svg class="questions-button" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="div-block-30">
              <div class="text-block-17">Medical expertise: John Reardon spent two decades treating accident victims as a chiropractor. Chiropractor relationships: He built one of the largest networks of ethical chiropractors in California. Personal attention: You work directly with an attorney, not a giant call-center firm. Aggressive representation with transparent communication from start to finish.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="sectionnn">
    <div class="w-layout-blockcontainer container-11 w-container">
      <div class="div-block-18">
        <h2 class="text-headings sr-up">Our Practice Areas</h2>
        <div class="text-block-10">Reardon Injury Law specializes in California auto accident cases and is committed to going above and beyond to protect our clients&#8217; rights. We understand the stress and pain that follow an accident, and we work tirelessly through a comprehensive legal process to advocate for you and secure the fair, just results you deserve.</div>
      </div>
      <div class="w-layout-blockcontainer w-container" style="max-width: 1200px;">
        <div class="stagger-container sr-stagger" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; padding: 20px;">
          <a href="/car-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Car Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/car.svg" alt="Car accident icon"> Car Accidents</h3><p>Injured in a car accident? We fight to get you full compensation for medical bills, lost wages, and pain and suffering.</p><span class="card-link-text">Learn More</span></div></a>
          <a href="/motorcycle-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Motorcycle Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/motorcycle.svg" alt="Motorcycle accident icon"> Motorcycle Accidents</h3><p>Motorcycle riders deserve aggressive representation. We understand the unique challenges bikers face after accidents.</p><span class="card-link-text">Learn More</span></div></a>
          <a href="/truck-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Truck Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/truck.svg" alt="Truck accident icon"> Truck Accidents</h3><p>Commercial truck accidents often cause catastrophic injuries. We take on trucking companies and their insurers.</p><span class="card-link-text">Learn More</span></div></a>
          <a href="/rideshare-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Rideshare Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/rideshare.svg" alt="Rideshare accident icon"> Rideshare Accidents</h3><p>Accidents involving Uber and Lyft have unique insurance complexities. We navigate them to protect your rights.</p><span class="card-link-text">Learn More</span></div></a>
          <a href="/pedestrian-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Pedestrian Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/pedestrian.svg" alt="Pedestrian accident icon"> Pedestrian Accidents</h3><p>When a vehicle strikes a pedestrian, the injuries can be life-altering. We hold negligent drivers accountable.</p><span class="card-link-text">Learn More</span></div></a>
          <a href="/bicycle-accidents" class="practice-area-card-link stagger-item reveal sr-child" aria-label="Learn more about Bicycle Accidents"><div class="practice-area-card"><h3><img class="practice-area-icon" src="/images/icons/bicycle.svg" alt="Bicycle accident icon"> Bicycle Accidents</h3><p>Cyclists are vulnerable on the road. We fight to ensure your rights and safety are respected after a collision.</p><span class="card-link-text">Learn More</span></div></a>
        </div>
        <div style="text-align: center; margin-top: 30px;">
          <a href="/practice-areas" class="button-3 w-button btn-secondary" style="display: inline-block;">View All Practice Areas</a>
        </div>
      </div>
    </div>
  </section>
  <section class="sectionnn client-test-section">
    <div class="w-layout-blockcontainer container-18 w-container">
      <div><h2 class="text-headings sr-left">Client Testimonials</h2></div>
    </div>
    <div class="w-layout-blockcontainer container-17 w-container">
      <div data-delay="4000" data-animation="slide" class="testimonial-slider w-slider" data-autoplay="true" data-easing="ease" data-hide-arrows="false" data-disable-swipe="false" data-autoplay-limit="0" data-nav-spacing="3" data-duration="500" data-infinite="true">
        <div class="w-slider-mask">
          <div class="w-slide"><div class="testimonial-slide-content"><div>&quot;Thank you very much for your hard work. I really appreciate all the help. At the beginning, the process was scary for me, but you and everybody at your firm helped me get through my fear. Everybody was helpful and kept me up-to-date on the process. I will definitely contact you if I need your services in the future. I will also recommend your firm to my family and friends as well.&quot; - Client, Edward Cadena</div></div></div>
          <div class="w-slide"><div class="testimonial-slide-content"><div class="text-block-16">&quot;An outstanding firm. They go above and beyond to give each client&#8217;s case the personal attention and detail it needs. Attorney Reardon and his firm are top notch and one of the best in my book.&quot; - Chiropractor C.F.</div></div></div>
          <div class="w-slide"><div class="testimonial-slide-content"><div>&quot;Reardon Law is always on top the fine details that can make or break a case. John always ensures that every I is dotted and every T is crossed, and manages the case efficiently to make sure that car crash victims not only get the best medical care they need, but also get compensated according to what the law entitles them to. Highly recommended!&quot; - Chiropractor, J.P.</div></div></div>
        </div>
        <div class="w-slider-arrow-left"><div class="icon-3 w-icon-slider-left"></div></div>
        <div class="w-slider-arrow-right"><div class="icon-2 w-icon-slider-right"></div></div>
        <div class="w-slider-nav w-slider-nav-invert w-round w-num"></div>
      </div>
    </div>
  </section>
  <section class="sectionnn">
    <div class="w-layout-blockcontainer container-18 w-container">
      <div><h2 class="text-headings sr-right">Office Locations</h2></div>
    </div>
    <div class="w-layout-blockcontainer container-17 w-container">
      <div class="office-locations"><img src="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif" loading="lazy" width="588" sizes="(max-width: 767px) 100vw, 588px" alt="" srcset="/images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-500.avif 500w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-800.avif 800w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1080.avif 1080w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-1600.avif 1600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2000.avif 2000w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash-p-2600.avif 2600w, /images/nicholas-ceglia-s5-5t9cWe2E-unsplash.avif 4032w" class="image-office-locations"><div><h2 class="heading-for-office-locations">Orange County</h2><div class="text-block-officelocations">20902 Brookhurst St 101<br>Huntington Beach | California | 92646</div></div></div>
      <div class="office-locations"><div><h2 class="heading-for-office-locations">Silicon Valley</h2><div class="text-block-officelocations">325 1st St. Suite 120<br>San Jose | California | 95113</div></div><img src="/images/hardik-pandya--Ey_0PMz900-unsplash.jpg" loading="lazy" width="651" sizes="(max-width: 767px) 100vw, 651px" alt="" srcset="/images/hardik-pandya--Ey_0PMz900-unsplash-p-500.jpg 500w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-800.jpg 800w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-1080.jpg 1080w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-1600.jpg 1600w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-2000.jpg 2000w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-2600.jpg 2600w, /images/hardik-pandya--Ey_0PMz900-unsplash-p-3200.jpg 3200w, /images/hardik-pandya--Ey_0PMz900-unsplash.jpg 4001w" class="image-office-locations"></div>
      <div class="office-locations"><img src="/images/cedric-letsch-FYDNbPE9Bw4-unsplash.jpg" loading="lazy" width="620" sizes="(max-width: 767px) 100vw, 620px" alt="" srcset="/images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-500.jpg 500w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-800.jpg 800w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-1080.jpg 1080w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-1600.jpg 1600w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-2000.jpg 2000w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash-p-2600.jpg 2600w, /images/cedric-letsch-FYDNbPE9Bw4-unsplash.jpg 3000w" class="image-office-locations"><div><h2 class="heading-for-office-locations">Inland Empire</h2><div class="text-block-officelocations">1014 N. D St. <br>San Bernardino | California | 92410</div></div></div>
      <div class="office-locations"><div><h2 class="heading-for-office-locations">San Diego County</h2><div class="text-block-officelocations">111 C St.<br>Encinitas | California | 92024</div></div><img src="/images/felix-wostmann-RIHKx32ACME-unsplash.jpg" loading="lazy" width="653" sizes="(max-width: 767px) 100vw, 653px" alt="" srcset="/images/felix-wostmann-RIHKx32ACME-unsplash-p-500.jpg 500w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-800.jpg 800w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-1080.jpg 1080w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-1600.jpg 1600w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-2000.jpg 2000w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-2600.jpg 2600w, /images/felix-wostmann-RIHKx32ACME-unsplash-p-3200.jpg 3200w, /images/felix-wostmann-RIHKx32ACME-unsplash.jpg 4898w" class="image-office-locations"></div>
      <div class="office-locations"><img src="/images/cedric-letsch-UZVlSjrIJ3o-unsplash.jpg" loading="lazy" width="681" sizes="(max-width: 767px) 100vw, 681px" alt="" srcset="/images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-500.jpg 500w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-800.jpg 800w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-1080.jpg 1080w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-1600.jpg 1600w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-2000.jpg 2000w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash-p-2600.jpg 2600w, /images/cedric-letsch-UZVlSjrIJ3o-unsplash.jpg 3000w" class="image-office-locations"><div><h2 class="heading-for-office-locations">Los Angeles County</h2><div class="text-block-officelocations">440 East Route 66<br>Glendora | California | 91740</div></div></div>
    </div>
  </section>
  <section class="form">
    <div class="w-layout-blockcontainer container-22 w-container">
      <div class="cta-header"><h2 class="cta-headerr sr-up">Contact us now!</h2></div>
      <div><div class="textblockk">Our team will follow up with you as soon as possible.</div></div>
      <div>
        <div class="w-form">
          <form id="home-contact-form" name="email-form" data-name="Email Form" method="POST" class="form-2">
            <input type="hidden" name="_subject" value="New Contact Form (Homepage) - Reardon Injury Law">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off">

            <label for="home-name" class="field-label-2">Name</label>
            <input class="text-field w-input" maxlength="256" name="name" data-name="Name" placeholder="" type="text" id="home-name">

            <label for="home-email" class="field-label">Email Address</label>
            <input class="text-field-2 w-input" maxlength="256" name="email" data-name="Email" placeholder="" type="email" id="home-email" required="">

            <label for="home-phone" class="field-label">Phone Number</label>
            <input class="text-field-2 w-input" maxlength="20" name="phone" data-name="Phone" placeholder="" type="tel" id="home-phone">

            <label for="home-message" class="field-label">Message to Our Team</label>
            <textarea class="text-field-2 w-input" maxlength="1000" name="message" data-name="Message" placeholder="" id="home-message" required=""></textarea>

            <input type="submit" data-wait="Please wait..." class="submit-button w-button" id="home-submit-btn" value="Submit">
          </form>
          <div class="w-form-done"><div>Thank you! Your submission has been received! We'll be in touch shortly.</div></div>
          <div class="w-form-fail"><div>Oops! Something went wrong. Please call us directly at (657) 522-7122.</div></div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var form = document.getElementById('home-contact-form');
      if (!form) return;
      var btn = document.getElementById('home-submit-btn');
      var wrapper = form.closest('.w-form');
      var done = wrapper.querySelector('.w-form-done');
      var fail = wrapper.querySelector('.w-form-fail');

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        btn.value = 'Sending...';
        btn.disabled = true;
        fail.style.display = 'none';

        var data = new FormData(form);

        fetch('https://formsubmit.co/ajax/clay@digitalascent.ai', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: data
        }).then(function(res) {
          if (res.ok) {
            form.style.display = 'none';
            done.style.display = 'block';
          } else {
            throw new Error('Submit failed');
          }
        }).catch(function() {
          fail.style.display = 'block';
          btn.value = 'Submit';
          btn.disabled = false;
        });
      });
    })();
  </script>
</BaseLayout>
