---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="California Truck Accident Lawyers | Reardon Injury Law" description="Injured in a truck accident in California? Reardon Injury Law takes on trucking companies and fights for maximum compensation. Free consultation." bodyClass="body-2" currentPage="practice-areas">
    <!-- Page Header -->
    <div style="background: #141415; padding: 60px 20px 30px; text-align: center; border-bottom: 1px solid rgba(238,186,107,0.2);">
      <div class="w-layout-blockcontainer w-container" style="max-width: 900px;">
        <h1 style="color: #eeba6b; font-family: Montserrat, sans-serif; font-size: 42px; font-weight: 700; margin-bottom: 16px;">California Truck Accident Lawyers</h1>
        <p style="color: rgba(255,255,255,0.85); font-family: 'Open Sans', sans-serif; font-size: 18px; line-height: 1.6; margin-bottom: 24px;">Trucking companies have powerful legal teams. We level the playing field and fight aggressively for everything you deserve.</p>
        <a href="tel:6575227122" style="display: inline-block; background: linear-gradient(180deg, #eeba6b 0%, #d4a84f 100%); color: #141415; padding: 14px 36px; border-radius: 8px; font-family: Montserrat, sans-serif; font-weight: 700; text-decoration: none; font-size: 16px;">Call (657) 522-7122 – Free Consultation</a>
      </div>
    </div>

    <!-- Why Choose Us Section -->
    <section class="sectionnn" style="padding: 80px 20px; background-color: #141415;">
      <div class="w-layout-blockcontainer w-container" style="max-width: 1100px;">
        <h2 class="text-headings" style="text-align: center; margin-bottom: 50px;">Why Choose Reardon Injury Law?</h2>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;">
          <div class="practice-area-card">
            <h3><img src="/images/icons/truck.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> Understands Trucking Regulations</h3>
            <p>Truck accident cases involve complex federal and state regulations — hours-of-service rules, weight limits, maintenance requirements. We know these regulations and use violations to strengthen your case.</p>
          </div>
          <div class="practice-area-card">
            <h3><img src="/images/icons/medical-expertise.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> Medical Expertise</h3>
            <p>John Reardon's 20+ years as a chiropractor means he understands catastrophic injuries at a clinical level — crush injuries, spinal trauma, and TBIs that are common in truck accidents.</p>
          </div>
          <div class="practice-area-card">
            <h3><img src="/images/icons/building.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> Takes on Big Companies</h3>
            <p>Trucking companies and their insurers have teams of lawyers. We're not intimidated. We take on large corporations and their aggressive defense teams to protect your rights.</p>
          </div>
          <div class="practice-area-card">
            <h3><img src="/images/icons/aggressive-representation.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> Aggressive Negotiation</h3>
            <p>Insurance companies know we're willing to go to trial. Our aggressive approach and thorough case preparation gets results that lowball settlement offers can't match.</p>
          </div>
          <div class="practice-area-card">
            <h3><img src="/images/icons/money.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> No Fees Unless We Win</h3>
            <p>Truck accident cases can be expensive to litigate. You pay nothing upfront — we invest our own resources and only get paid when we recover compensation for you.</p>
          </div>
          <div class="practice-area-card">
            <h3><img src="/images/icons/scales.svg" alt="" style="width:40px;height:40px;vertical-align:middle;margin-right:10px;"> Proven Results</h3>
            <p>We've recovered millions for accident victims across California. Trucking companies and their insurers know our reputation for thorough preparation and aggressive advocacy.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Common Injuries Section -->
    <section class="sectionnn" style="padding: 80px 20px; background: linear-gradient(180deg, #1e1e1f 0%, #141415 100%);">
      <div class="w-layout-blockcontainer w-container" style="max-width: 900px;">
        <h2 class="text-headings sr-up" style="text-align: center; margin-bottom: 20px;">Truck Accident Injuries &amp; Cases We Handle</h2>
        <p style="color: rgba(255,255,255,0.8); text-align: center; font-family: 'Open Sans', sans-serif; margin-bottom: 40px;">Commercial truck accidents often cause the most severe injuries on the road. We help victims of:</p>

        <div class="sr-stagger" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/pain.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Catastrophic Crush Injuries</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">The sheer size and weight of commercial trucks means collisions often cause devastating crush injuries that require extensive surgery, rehabilitation, and lifelong care.</p>
          </div>
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/spine.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Spinal Cord Injuries</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">Truck accidents frequently cause spinal cord damage leading to partial or complete paralysis. We fight for the lifetime of medical care and compensation these injuries demand.</p>
          </div>
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/brain.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Traumatic Brain Injuries</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">The violent force of a truck collision can cause severe TBIs that affect memory, cognition, personality, and the ability to work — often permanently.</p>
          </div>
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/bone.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Broken Bones &amp; Amputations</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">Truck accidents can cause compound fractures and traumatic amputations that permanently alter victims' lives. We pursue full compensation for these life-changing injuries.</p>
          </div>
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/shield.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Internal Organ Damage</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">Internal bleeding and organ damage from blunt force trauma can be life-threatening and may not show symptoms immediately. Our medical background helps identify these hidden injuries early.</p>
          </div>
          <div class="sr-child" style="background: rgba(238,186,107,0.1); border-left: 4px solid #eeba6b; padding: 20px; border-radius: 0 8px 8px 0;">
            <img src="/images/icons/wrongful-death.svg" alt="" style="width:36px;height:36px;margin-bottom:10px;display:block;">
            <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 10px;">Wrongful Death</h4>
            <p style="color: #fff; font-family: 'Open Sans', sans-serif; font-size: 15px; line-height: 1.6;">Truck accidents are among the most deadly on California roads. We help grieving families pursue wrongful death claims to recover funeral costs, lost income, and damages for their loss.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What to Do After an Accident -->
    <section class="sectionnn" style="padding: 80px 20px; background-color: #141415;">
      <div class="w-layout-blockcontainer w-container" style="max-width: 900px;">
        <h2 class="text-headings sr-up" style="text-align: center; margin-bottom: 40px;">What to Do After a Truck Accident</h2>

        <div class="sr-stagger" style="display: flex; flex-direction: column; gap: 25px;">
          <div class="sr-child" style="display: flex; gap: 20px; align-items: flex-start;">
            <div style="background: #eeba6b; color: #141415; font-family: Montserrat, sans-serif; font-weight: 700; font-size: 24px; min-width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">1</div>
            <div>
              <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 8px;">Get Emergency Care</h4>
              <p style="color: #fff; font-family: 'Open Sans', sans-serif; line-height: 1.6;">Truck accident injuries are often severe. Call 911 and get emergency medical treatment immediately. Your health is the top priority.</p>
            </div>
          </div>

          <div class="sr-child" style="display: flex; gap: 20px; align-items: flex-start;">
            <div style="background: #eeba6b; color: #141415; font-family: Montserrat, sans-serif; font-weight: 700; font-size: 24px; min-width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">2</div>
            <div>
              <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 8px;">Preserve Evidence</h4>
              <p style="color: #fff; font-family: 'Open Sans', sans-serif; line-height: 1.6;">Black box data and electronic logs can disappear fast. Take photos of the scene, the truck, and any visible company markings or DOT numbers.</p>
            </div>
          </div>

          <div class="sr-child" style="display: flex; gap: 20px; align-items: flex-start;">
            <div style="background: #eeba6b; color: #141415; font-family: Montserrat, sans-serif; font-weight: 700; font-size: 24px; min-width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">3</div>
            <div>
              <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 8px;">Identify All Liable Parties</h4>
              <p style="color: #fff; font-family: 'Open Sans', sans-serif; line-height: 1.6;">Truck accidents may involve the driver, trucking company, cargo loader, and maintenance provider. Multiple parties may owe you compensation.</p>
            </div>
          </div>

          <div class="sr-child" style="display: flex; gap: 20px; align-items: flex-start;">
            <div style="background: #eeba6b; color: #141415; font-family: Montserrat, sans-serif; font-weight: 700; font-size: 24px; min-width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">4</div>
            <div>
              <h4 style="color: #eeba6b; font-family: Montserrat, sans-serif; margin-bottom: 8px;">Call Reardon Injury Law</h4>
              <p style="color: #fff; font-family: 'Open Sans', sans-serif; line-height: 1.6;">Time is critical in truck accident cases. Trucking companies send investigators to the scene immediately. You need an attorney fighting for you just as fast.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section class="form" style="padding: 80px 20px; background: linear-gradient(180deg, #1e1e1f 0%, #141415 100%);">
      <div class="w-layout-blockcontainer container-22 w-container" style="max-width: 600px;">
        <div class="cta-header">
          <h2 class="cta-headerr sr-up" style="color: #eeba6b; text-align: center;">Get Your Free Case Review</h2>
        </div>
        <div style="text-align: center; margin-bottom: 30px;">
          <div class="textblockk" style="color: rgba(255,255,255,0.9);">Tell us about your truck accident. We'll review your case and call you back within 24 hours.</div>
        </div>
        <div>
          <div class="w-form sr-up">
            <form id="truck-accident-form" name="truck-accident-form" data-name="Truck Accident Form" method="get" class="form-2">
              <label for="name-truck" class="field-label-2">Name</label>
              <input class="text-field w-input" maxlength="256" name="name" data-name="Name" placeholder="Your full name" type="text" id="name-truck" required="">

              <label for="email-truck" class="field-label">Email Address</label>
              <input class="text-field-2 w-input" maxlength="256" name="email" data-name="Email" placeholder="your@email.com" type="email" id="email-truck" required="">

              <label for="phone-truck" class="field-label">Phone Number</label>
              <input class="text-field-2 w-input" maxlength="256" name="phone" data-name="Phone" placeholder="(555) 123-4567" type="tel" id="phone-truck" required="">

              <label for="message-truck" class="field-label">Tell Us About Your Accident</label>
              <textarea class="text-field-2 w-input" maxlength="2000" name="message" data-name="Message" placeholder="When did the accident happen? What injuries did you sustain?" id="message-truck" required="" style="min-height: 120px;"></textarea>

              <input type="submit" data-wait="Please wait..." class="submit-button w-button" value="Request Free Consultation">
            </form>
            <div class="w-form-done">
              <div>Thank you! We'll contact you within 24 hours.</div>
            </div>
            <div class="w-form-fail">
              <div>Oops! Something went wrong. Please call us directly at (657) 522-7122.</div>
            </div>
          </div>
        </div>
      </div>
    </section>
</BaseLayout>
